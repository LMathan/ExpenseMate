rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (needed for name/email search).
      allow read: if request.auth != null;

      // Only the owner writes their own profile document.
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Groups subcollection ─────────────────────────────────────────────
      // A group document may be created/updated by any authenticated user whose
      // UID appears in the document's memberUids list — this lets User A push the
      // group to User B's subcollection when B is a member.
      // Only the owner (B) may delete documents from their own subcollection.
      match /groups/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
            && request.resource.data.keys().hasAll(['memberUids'])
            && request.auth.uid in request.resource.data.memberUids;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // ── Transactions subcollection ───────────────────────────────────────
      // Owner can always write their own transactions.
      // Any authenticated user may also push a group transaction (groupId != '')
      // to another member's subcollection so every member sees split expenses.
      match /transactions/{txId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
            && (request.auth.uid == userId
                || (request.resource.data.keys().hasAll(['groupId'])
                    && request.resource.data.groupId is string
                    && request.resource.data.groupId != ''));
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // ── All other private subcollections ─────────────────────────────────
      // Retention policy: the app calls cleanupOldData() on every sync and a
      // Firebase Console TTL policy on the `expireAt` Timestamp field handles
      // server-side auto-deletion for transactions.
      match /{subCollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
